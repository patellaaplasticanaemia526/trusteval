# =============================================
# TrustEval Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================

# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
HUGGINGFACE_API_KEY=hf_...

# Dashboard Security
TRUSTEVAL_DASHBOARD_KEY=your-secret-dashboard-key-here

# Dashboard Configuration
TRUSTEVAL_DASHBOARD_HOST=0.0.0.0
TRUSTEVAL_DASHBOARD_PORT=8080
TRUSTEVAL_FRONTEND_URL=http://localhost:3000

# Evaluation Defaults
TRUSTEVAL_DEFAULT_INDUSTRY=healthcare
TRUSTEVAL_DEFAULT_PILLARS=bias,hallucination,pii,toxicity
TRUSTEVAL_MAX_TEST_COUNT=100
TRUSTEVAL_TIMEOUT_SECONDS=30

# Data Storage
TRUSTEVAL_DATA_DIR=~/.trusteval
TRUSTEVAL_STORE_PROMPTS=false
TRUSTEVAL_LOG_LEVEL=INFO

# Rate Limiting
TRUSTEVAL_RATE_LIMIT_RPM=60

# CORS (comma-separated)
TRUSTEVAL_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
